# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=dev_secret_key_change_me_in_production

# Database Connection (MySQL)
# Format: mysql+pymysql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/smart_campus

# Hugging Face Configuration (For Chatbot & Image Classification)
# Get a token from: https://huggingface.co/settings/tokens
HF_API_TOKEN=your_hugging_face_api_token_here

# Cloudinary Configuration (For Image Storage)
# Get credentials from Cloudinary Dashboard: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Configuration (SMTP)
# For Gmail, generate an App Password: https://myaccount.google.com/apppasswords
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM_EMAIL=your_email@gmail.com
